---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHOR_NAME, SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<!-- TODO: swap for a real mascot/emblem image once you have one -->
				<div class="avatar" aria-hidden="true">
					{
						AUTHOR_NAME.split(' ')
							.map((word) => word[0])
							.join('')
							.slice(0, 2)
					}
				</div>
				<div class="intro">
					<h1>{AUTHOR_NAME}</h1>
					<!-- TODO: replace with real intro copy -->
					<p class="tagline">[Intro copy goes here -- a couple sentences on what this blog covers and why.]</p>
					<div class="social-links">
						<a href={SOCIAL_LINKS.github} target="_blank">GitHub</a>
						<a href={SOCIAL_LINKS.x} target="_blank">X</a>
						<a href={SOCIAL_LINKS.email}>Email</a>
					</div>
				</div>
			</section>

			{
				recentPosts.length > 0 && (
					<section class="recent-posts">
						<h2>Recent posts</h2>
						<ul>
							{recentPosts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<span class="title">{post.data.title}</span>
										<FormattedDate date={post.data.pubDate} />
									</a>
								</li>
							))}
						</ul>
						<a class="see-all" href="/blog">See all posts &rarr;</a>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: flex;
		align-items: center;
		gap: 1.5em;
		margin-bottom: 2em;
	}
	.avatar {
		flex-shrink: 0;
		width: 96px;
		height: 96px;
		border-radius: 50%;
		background: var(--accent);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2em;
		font-weight: 700;
	}
	.intro h1 {
		margin-bottom: 0.25rem;
	}
	.tagline {
		color: rgb(var(--gray));
	}
	.social-links {
		display: flex;
		gap: 1em;
	}
	.recent-posts {
		border-top: 1px solid rgb(var(--gray-light));
		padding-top: 2em;
	}
	.recent-posts ul {
		list-style: none;
		margin: 0 0 1em 0;
		padding: 0;
	}
	.recent-posts li a {
		display: flex;
		justify-content: space-between;
		gap: 1em;
		padding: 0.75em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		text-decoration: none;
	}
	.recent-posts li a:hover .title {
		color: var(--accent);
	}
	.recent-posts .title {
		color: rgb(var(--black));
	}
	.see-all {
		font-weight: 700;
	}
	@media (max-width: 480px) {
		.hero {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
